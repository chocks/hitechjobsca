# Copy to .env and adjust as needed. Used by docker-compose.yml.

# --- Postgres (api + db service) ---
POSTGRES_DB=jodb
POSTGRES_USER=developer
POSTGRES_PASSWORD=developer

# --- apps/sync (jobs ingest; optional) ---
# Run the ingest on a loop every N seconds (default: run once and exit)
# SYNC_INTERVAL_SECONDS=3600
# Dry-run: fetch + parse but skip the DB write
# SYNC_DRY_RUN=1
# GitHub token to raise the unauthenticated issues API rate limit
# SYNC_GITHUB_TOKEN=ghp_xxx
